# FleetCare — vzor konfigurácie. Skopíruj na `.env` a vyplň. NEVERZUJ `.env` do gitu!
# Stav: VO VÝVOJI — hodnoty nižšie sú len ukážkové.

# ── Databáza (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_USER=fleetcare
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fleetcare

# ── Porty (host) ──────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=8080

# ── Verzia buildu (yyyymmddhhmm) ──────────────────────────────────────
# Lokálny build: nechaj "dev", alebo nastav časovú pečiatku pri builde:
#   BUILD_VERSION=$(date -u +%Y%m%d%H%M) docker compose up -d --build
BUILD_VERSION=dev

# ── Beh z GHCR images (docker-compose.ghcr.yml) ───────────────────────
GHCR_OWNER=jakicuk     # GHCR namespace (malými písmenami)
IMAGE_TAG=latest       # alebo konkrétny yyyymmddhhmm tag, napr. 202606081422

# ── Bezpečnosť / JWT ──────────────────────────────────────────────────
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
CORS_ORIGINS=http://localhost:8080

# ── Lokalizácia ───────────────────────────────────────────────────────
TZ=Europe/Bratislava
DEFAULT_LOCALE=sk

# ── Iniciálny admin (vytvorí seed pri prvom štarte) ───────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@fleetcare.local

# Naplniť demo dátami (autá/záznamy podľa mockupu)? true/false
SEED_DEMO=false

# ── Frontend ──────────────────────────────────────────────────────────
VITE_API_BASE=/api

# ── SMTP (e-mail notifikácie) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls          # tls | ssl | none
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=FleetCare <fleet@example.com>

# ── Matrix (notifikácie) ──────────────────────────────────────────────
MATRIX_ENABLED=false
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_TOKEN=
MATRIX_DEFAULT_ROOM=#fleet-alerts:matrix.example.com
