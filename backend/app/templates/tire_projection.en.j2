{% extends "_base.j2" %}
{% set lang = "en" %}
{% block content %}
  <h2 style="margin:0 0 12px;font-size:20px;">Tires are nearing the 1.6 mm limit</h2>
  <p style="margin:0 0 16px;font-size:14px;line-height:1.6;">
    For vehicle <strong>{{ car_name }}</strong>, the
    <strong>{{ tire_set_name }}</strong> set is projected to reach the minimum
    legal tread depth soon.
  </p>
  <table role="presentation" cellpadding="0" cellspacing="0" style="font-size:14px;">
    {% if avg_tread_mm is not none %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Average tread</td><td style="padding:4px 0;font-weight:600;">{{ '%.1f' | format(avg_tread_mm) }} mm</td></tr>{% endif %}
    {% if projection_date %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Projected change</td><td style="padding:4px 0;font-weight:600;color:#d97706;">{{ projection_date }}</td></tr>{% endif %}
    {% if expected_change_date %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Planned change</td><td style="padding:4px 0;font-weight:600;">{{ expected_change_date }}</td></tr>{% endif %}
  </table>
{% endblock %}
{% block footer %}This message was sent automatically by FleetCare (smart notification).{% endblock %}
