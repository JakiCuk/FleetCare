{% extends "_base.j2" %}
{% set lang = "en" %}
{% block content %}
  <h2 style="margin:0 0 12px;font-size:20px;">A document is expiring soon</h2>
  <p style="margin:0 0 16px;font-size:14px;line-height:1.6;">
    The <strong>{{ item_name_en }}</strong> for vehicle
    <strong>{{ car_name }}</strong> is approaching its expiry date.
  </p>
  <table role="presentation" cellpadding="0" cellspacing="0" style="font-size:14px;">
    <tr><td style="padding:4px 16px 4px 0;color:#64748b;">Document</td><td style="padding:4px 0;font-weight:600;">{{ item_label }}</td></tr>
    <tr><td style="padding:4px 16px 4px 0;color:#64748b;">Valid until</td><td style="padding:4px 0;font-weight:600;">{{ valid_until }}</td></tr>
    <tr><td style="padding:4px 16px 4px 0;color:#64748b;">Remaining</td><td style="padding:4px 0;font-weight:600;color:#d97706;">{{ days_left }} days</td></tr>
  </table>
{% endblock %}
{% block footer %}This message was sent automatically by FleetCare. Check the deadline in your dashboard.{% endblock %}
