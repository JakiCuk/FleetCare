{% extends "_base.j2" %}
{% set lang = "sk" %}
{% block content %}
  <h2 style="margin:0 0 12px;font-size:20px;">Pneumatiky sa blížia k hranici 1,6 mm</h2>
  <p style="margin:0 0 16px;font-size:14px;line-height:1.6;">
    Pre vozidlo <strong>{{ car_name }}</strong> sada
    <strong>{{ tire_set_name }}</strong> podľa predikcie čoskoro dosiahne
    minimálnu hĺbku dezénu.
  </p>
  <table role="presentation" cellpadding="0" cellspacing="0" style="font-size:14px;">
    {% if avg_tread_mm is not none %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Priemerný dezén</td><td style="padding:4px 0;font-weight:600;">{{ '%.1f' | format(avg_tread_mm) }} mm</td></tr>{% endif %}
    {% if projection_date %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Odhad výmeny</td><td style="padding:4px 0;font-weight:600;color:#d97706;">{{ projection_date }}</td></tr>{% endif %}
    {% if expected_change_date %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Plánovaná výmena</td><td style="padding:4px 0;font-weight:600;">{{ expected_change_date }}</td></tr>{% endif %}
  </table>
{% endblock %}
{% block footer %}Túto správu poslal FleetCare automaticky (smart notifikácia).{% endblock %}
