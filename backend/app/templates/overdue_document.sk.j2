{% extends "_base.j2" %}
{% set lang = "sk" %}
{% block content %}
  <h2 style="margin:0 0 12px;font-size:20px;color:#dc2626;">Doklad je po termíne!</h2>
  <p style="margin:0 0 16px;font-size:14px;line-height:1.6;">
    Pre vozidlo <strong>{{ car_name }}</strong> exspiroval doklad
    <strong>{{ item_name_sk }}</strong>. Vybavte obnovu čo najskôr.
  </p>
  <table role="presentation" cellpadding="0" cellspacing="0" style="font-size:14px;">
    <tr><td style="padding:4px 16px 4px 0;color:#64748b;">Doklad</td><td style="padding:4px 0;font-weight:600;">{{ item_label }}</td></tr>
    <tr><td style="padding:4px 16px 4px 0;color:#64748b;">Platnosť do</td><td style="padding:4px 0;font-weight:600;">{{ valid_until }}</td></tr>
    <tr><td style="padding:4px 16px 4px 0;color:#64748b;">Po termíne o</td><td style="padding:4px 0;font-weight:700;color:#dc2626;">{{ -days_left }} dní</td></tr>
  </table>
{% endblock %}
{% block footer %}Túto správu poslal FleetCare automaticky.{% endblock %}
