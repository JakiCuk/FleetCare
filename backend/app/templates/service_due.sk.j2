{% extends "_base.j2" %}
{% set lang = "sk" %}
{% block content %}
  <h2 style="margin:0 0 12px;font-size:20px;">Blíži sa servisný interval</h2>
  <p style="margin:0 0 16px;font-size:14px;line-height:1.6;">
    Pre vozidlo <strong>{{ car_name }}</strong> sa blíži servis
    <strong>{{ interval_name }}</strong>.
  </p>
  <table role="presentation" cellpadding="0" cellspacing="0" style="font-size:14px;">
    {% if km_left is not none %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Zostáva</td><td style="padding:4px 0;font-weight:600;">{{ km_left }} km</td></tr>{% endif %}
    {% if days_left is not none %}<tr><td style="padding:4px 16px 4px 0;color:#64748b;">Zostáva</td><td style="padding:4px 0;font-weight:600;">{{ days_left }} dní</td></tr>{% endif %}
  </table>
{% endblock %}
{% block footer %}Túto správu poslal FleetCare automaticky.{% endblock %}
